# URL de tu proyecto Supabase (ej: https://xxxx.supabase.co)
SUPABASE_URL=https://your-project.supabase.co

# Service Role Key (Settings > API > service_role) — nunca expongas esta clave al frontend
SUPABASE_SERVICE_KEY=your-service-role-key

# JWT Secret (Settings > API > JWT Secret) — para validar tokens de usuarios
SUPABASE_JWT_SECRET=your-jwt-secret

# Puerto donde escucha el servidor (por defecto 8080)
PORT=8080

# Orígenes CORS permitidos (separados por coma)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173
